# HOMER.io Caddy Configuration
#
# NOTE: The web app sets a Content-Security-Policy via <meta http-equiv> in
# packages/web/index.html. If you want a stricter edge-enforced CSP, you can
# add a `header Content-Security-Policy "..."` line to the homer.discordwell.com
# block below — the response header takes precedence over the meta tag.
# See packages/web/index.html for the canonical policy and rationale.

# Demo site — preserved at homer.discordwell.com
homer.discordwell.com {
	root * /opt/homer-io/site
	file_server
	try_files {path} /index.html
}

# Product app — app.homer.io
app.homer.io {
	reverse_proxy localhost:3001
}

# API — api.homer.io
api.homer.io {
	reverse_proxy localhost:3000
}

# Public tracking pages
track.homer.io {
	reverse_proxy localhost:3000
}
