{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "mobile:start": {
      "cache": false,
      "persistent": true
    },
    "mobile:build": {
      "dependsOn": ["^build"],
      "outputs": [".expo/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.js",
        "src/**/*.jsx",
        "app/**/*.ts",
        "app/**/*.tsx",
        "eslint.config.js",
        "../../eslint.config.js"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "app/**/*.ts",
        "app/**/*.tsx",
        "tsconfig.json",
        "../../tsconfig.base.json"
      ],
      "outputs": []
    }
  }
}
