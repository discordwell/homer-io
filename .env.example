# Database
DATABASE_URL=postgresql://homer:homer@localhost:5432/homer

# Redis
REDIS_URL=redis://localhost:6379

# JWT — REQUIRED in every environment (dev, staging, prod, CI).
# The API will refuse to start if this is missing. For local development you
# can use the placeholder below, but rotate to a real 64-char random string
# before deploying anywhere reachable. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-only-change-me-rotate-in-prod-0123456789abcdef0123456789abcdef

# CORS
CORS_ORIGIN=http://localhost:3001,https://app.homer.io
APP_FRONTEND_URL=https://homer.discordwell.com

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=homer
MINIO_SECRET_KEY=homerdev123
MINIO_BUCKET=homer

# Anthropic (used for AI chat features)
ANTHROPIC_API_KEY=

# OSRM (self-hosted routing engine for distance matrices)
OSRM_URL=http://localhost:5000

# Google Routes API (traffic-aware customer-facing ETAs)
GOOGLE_ROUTES_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_ANNUAL=

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid (email notifications)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@homer.io

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
