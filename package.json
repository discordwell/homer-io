{
  "name": "homer-io",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:api": "npm run dev -w @homer-io/api",
    "dev:web": "npm run dev -w @homer-io/web",
    "dev:worker": "npm run dev -w @homer-io/worker",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "audit:prep": "node scripts/audit/prepare.mjs",
    "audit:inventory": "node scripts/audit/inventory.mjs",
    "audit:cycle": "node scripts/audit/cycle.mjs",
    "audit:report": "node scripts/audit/report.mjs",
    "audit:browser:public": "node scripts/audit/browser-public.mjs",
    "audit:test": "node --test scripts/audit/lib/*.test.mjs",
    "db:generate": "npm run db:generate -w @homer-io/api",
    "db:migrate": "npm run db:migrate -w @homer-io/api"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "turbo": "^2.5.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.5"
  },
  "overrides": {
    "@rollup/plugin-terser": "^1.0.0",
    "serialize-javascript": "^7.0.5"
  }
}
