# vite-plugin-pwa@1.2.0 (latest) declares peerDependencies.vite=^3|^4|^5|^6|^7
# but we're on vite@^8.0.5 (security bump for GHSA-4w7w/v2wj/p9ff — path
# traversal, fs.deny bypass, WebSocket arbitrary file read). vite@8 is
# API-compatible with vite-plugin-pwa's actual usage; drop this once
# vite-plugin-pwa publishes a release listing ^8.0.0 in its peer range.
legacy-peer-deps=true
